{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/PaulKov/de-mentor/blob/master/contracts/academy-session/v1/session.schema.json",
  "title": "Academy Session v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "academy_version",
    "lab_name",
    "student_name",
    "created_at",
    "current_stage",
    "stages",
    "skill_graph",
    "commands",
    "events",
    "portal"
  ],
  "properties": {
    "contract_version": {
      "const": "academy-session/v1"
    },
    "academy_version": {
      "type": "string"
    },
    "lab_name": {
      "type": "string"
    },
    "student_name": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "current_stage": {
      "$ref": "#/$defs/stage"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage"
      }
    },
    "skill_graph": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skill"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "control_plane": {
      "$ref": "#/$defs/controlPlane"
    },
    "portal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "framework",
        "repository",
        "app_path",
        "session_env",
        "dev_command"
      ],
      "properties": {
        "framework": {
          "const": "Vue 3 + Nuxt 3 + Vite"
        },
        "repository": {
          "const": "https://github.com/PaulKov/de-mentor-portal"
        },
        "app_path": {
          "const": "de-mentor-portal"
        },
        "session_env": {
          "const": "MENTOR_LAB_SESSION"
        },
        "dev_command": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "title",
        "timebox",
        "mentor_focus",
        "student_action",
        "command"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "timebox": {
          "type": "string"
        },
        "mentor_focus": {
          "type": "string"
        },
        "student_action": {
          "type": "string"
        },
        "command": {
          "type": "string"
        }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "title",
        "level",
        "evidence"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "level": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_type",
        "note",
        "created_at"
      ],
      "properties": {
        "event_type": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        }
      }
    },
    "controlPlane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "mentor_mode",
        "student_mode",
        "portal_actions",
        "artifacts",
        "next_lesson"
      ],
      "properties": {
        "version": {
          "const": "academy-control-plane/v1"
        },
        "mentor_mode": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "default_route",
            "runbook_commands",
            "slide_deck",
            "stage_guides"
          ],
          "properties": {
            "default_route": {
              "type": "string"
            },
            "runbook_commands": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "slide_deck": {
              "type": "string"
            },
            "google_slides": {
              "type": [
                "string",
                "null"
              ]
            },
            "stage_guides": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/stageGuide"
              }
            }
          }
        },
        "student_mode": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "prep_runbook",
            "workbook",
            "homework",
            "self_check_commands"
          ],
          "properties": {
            "prep_runbook": {
              "type": "string"
            },
            "workbook": {
              "type": "string"
            },
            "homework": {
              "type": "string"
            },
            "self_check_commands": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "portal_actions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start_command",
            "export_command",
            "open_command"
          ],
          "properties": {
            "start_command": {
              "type": "string"
            },
            "export_command": {
              "type": "string"
            },
            "open_command": {
              "type": "string"
            }
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "next_lesson": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "code",
            "title",
            "path"
          ],
          "properties": {
            "code": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "path": {
              "type": "string"
            }
          }
        }
      }
    },
    "stageGuide": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_code",
        "slides",
        "mentor_script",
        "show_commands",
        "question",
        "expected_answer",
        "verification",
        "workbook_ref",
        "homework_ref"
      ],
      "properties": {
        "stage_code": {
          "type": "string"
        },
        "slides": {
          "type": "string"
        },
        "mentor_script": {
          "type": "string"
        },
        "show_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "question": {
          "type": "string"
        },
        "expected_answer": {
          "type": "string"
        },
        "verification": {
          "type": "string"
        },
        "workbook_ref": {
          "type": "string"
        },
        "homework_ref": {
          "type": "string"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "label"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    }
  }
}
